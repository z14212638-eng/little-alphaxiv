# Little Alphaxiv — Docker Compose env file (deploy/.env)
#
# Copy to `.env` (next to docker-compose.yml in deploy/) and adjust. ALL fields
# are optional — `cd deploy && docker compose up -d` works with no file at all,
# because the entrypoint auto-generates LAX_SECRET_KEY into the ./data volume on
# first run.
#
# This file is for Docker Compose variable interpolation only.
# The backend's full set of vars is documented in backend/.env.example.
#
# The ./data volume (bind-mounted to /app/data) holds the SQLite DB, the PDF
# cache (incl. uploaded / Zotero-imported PDFs under pdf_cache/uploads/<user_id>/,
# served auth-gated per-user), and the persisted LAX_SECRET_KEY — back it up to
# keep users' data + encrypted keys intact across rebuilds.

# Host port the app is exposed on (container always listens on 8000 internally).
LAX_PORT=8000

# Browser origins allowed for CORS. With the bundled same-origin setup
# (frontend served by the backend on the same port) you usually don't need to
# change this. Add your LAN/host origin for cross-origin access, e.g.:
#   LAX_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://192.168.1.50:8000
LAX_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Set true when behind HTTPS so the session cookie gets the Secure flag.
LAX_SECURE_COOKIES=false

# Session cookie + row lifetime, in days.
LAX_SESSION_MAX_AGE_DAYS=30

# --- Password recovery (optional) ---
# SMTP URL for sending password-reset emails. Unset/empty → reset links are
# printed to the container logs:  docker compose logs little-alphaxiv
# Gmail: use an app password, not your account password.
# LAX_SMTP_URL=smtps://user:pass@smtp.gmail.com:465
# LAX_SMTP_FROM=you@example.com
LAX_PASSWORD_RESET_TTL_MIN=30

# --- Zotero web proxy (Docker Desktop on Windows — fix for ReadTimeout/RST) ---
# Docker Desktop's container egress bypasses the host's system proxy (Clash/V2Ray
# at 127.0.0.1:7890 on the Windows host), so from inside a container
# api.zotero.org is reached over the raw NIC. On networks that intermittently
# throttle api.zotero.org this shows up as persistent "ReadTimeout" or
# "web-unreachable:" in the Zotero panel. Route ONLY the Zotero web calls
# through a proxy the container can reach:
#
#   1. In Clash: enable "Allow LAN" (binds 0.0.0.0:7890, not just 127.0.0.1).
#      The container cannot reach a loopback-only proxy.
#   2. Set this to the host as seen from the container:
LAX_ZOTERO_PROXY=http://host.docker.internal:7890
#   3. `docker compose up -d` to apply, then refresh the browser.
#
# Only Zotero WEB calls are proxied (arXiv / PDF / LLM stay direct). Empty/unset
# = direct (default). Local Zotero (127.0.0.1:23119) is never proxied.

# --- Local-first Zotero PDF import (recommended over the proxy above) ---
# The cloud PDF download (api.zotero.org -> S3) is flaky from a container's raw
# NIC. Local-first reads the PDF straight off the host disk via the local Zotero
# API's file:// redirect — fast, proxy-free, and immune to Zotero cloud-storage
# quota limits (a file not synced to zotero.org is still on local disk).
#
# Native (run.bat) works with NO config. Docker needs both:
#   1. Point the container at the host's local Zotero API:
LAX_ZOTERO_LOCAL_BASE=http://host.docker.internal:23119
#   2. The host Zotero storage folder (so it can be read-only mounted into the
#      container at /zotero-storage). Find it via Zotero -> Help -> Storage
#      Location -> Show Data Directory (the 'storage' subfolder), or run on the
#      host: curl -sI http://127.0.0.1:23119/api/users/0/items/<any-key>/file
#      and read the file:// path's prefix. Windows example:
# LAX_ZOTERO_STORAGE_DIR=C:/Users/you/Zotero/storage
#
# Both unset -> local-first disabled; import falls back to the (retried, capped)
# cloud download. Refresh the browser after changing these + `docker compose up -d`.

# --- General web search (anysearch MCP) — find non-arXiv papers ---
# The web_search tool lets the assistant find papers arXiv/OpenAlex/Semantic
# Scholar miss (IEEE/ACM/Springer, paywalled, DOI-only) and answer non-academic
# questions. It calls the anysearch MCP server over HTTP with this API key.
# Without it, web_search reports "not configured" and the model falls back to
# the academic search tools (no crash). It's the same ANYSEARCH_API_KEY your
# Claude Code MCP config can reference.
# ANYSEARCH_API_KEY=
# Optional: override the MCP endpoint URL (default https://api.anysearch.com/mcp).
# LAX_ANYSEARCH_URL=https://api.anysearch.com/mcp

