# Little Alphaxiv backend — stateless CORS proxy
#
# Copy to .env and adjust if needed. The server stores NOTHING; these are
# runtime knobs only.

# Where to cache downloaded arXiv PDFs (disk cache, keyed by arxiv id).
# Default: ~/.little_alphaxiv/pdf_cache
# LAX_PDF_CACHE=/path/to/cache

# Host/port are set on the command line in run.sh / run.ps1.
