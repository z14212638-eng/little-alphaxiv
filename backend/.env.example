# Little Alphaxiv backend — CORS proxy + per-user persistence + auth
#
# Copy to .env and adjust if needed.

# --- PDF disk cache ---
# Where to cache downloaded arXiv PDFs (disk cache, keyed by arxiv id).
# run.sh/run.bat set this to ../deploy/data/pdf_cache (shared with Docker).
# Fallback default (direct uvicorn, no run script): backend/data/pdf_cache.
# LAX_PDF_CACHE=/path/to/cache

# --- Persistence + auth ---
# SQLite database file. Relative paths resolve under backend/.
# run.sh/run.bat set this to ../deploy/data/little_alphaxiv.db so native dev
# shares the Docker data dir (deploy/data/). Fallback (direct uvicorn):
# backend/data/little_alphaxiv.db. The Fernet secret key + reset-link log
# live NEXT TO this DB file.
LAX_DATABASE_URL=sqlite:///./data/little_alphaxiv.db

# Secret key for encrypting stored API keys at rest (Fernet) AND signing session
# cookies (itsdangerous). If unset, the server auto-generates one and persists it
# next to the DB (deploy/data/.lax_secret_key via run scripts or Docker; falls
# back to backend/data/.lax_secret_key for direct uvicorn) — stable across
# restarts. On upgrade from the old backend/.env location, the existing key is
# migrated automatically. To set your own (recommended in production):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# LAX_SECRET_KEY=

# Cookie secure flag. False for LAN http (default); True behind https.
LAX_SECURE_COOKIES=false

# Allowed browser origins for CORS (comma-separated). With credentials, "*" is
# illegal — must enumerate. Dev: the Vite proxy origin.
LAX_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Session lifetime in days.
LAX_SESSION_MAX_AGE_DAYS=30

# --- Password recovery (email reset) ---
# SMTP URL for sending password-reset emails. Unset → reset links are printed
# to the server terminal + appended to deploy/data/lax_reset_links.log (localhost,
# zero-config). When set, real email is sent via smtplib (network IO runs in a
# worker thread so the event loop isn't blocked; send failures are logged and
# swallowed — the forgot-password endpoint never 500s).
#   smtps://user:pass@smtp.gmail.com:465          (implicit TLS)
#   smtp://user:pass@mail.host:587                 (STARTTLS, default on 587)
#   smtp://user:pass@mail.host:587?starttls=false  (plain, not recommended)
#   smtp://user:pass@mail.host:587?from=hi@x.com   (override From: address)
# LAX_SMTP_URL=
# From: address for reset emails (defaults to the SMTP URL user).
# LAX_SMTP_FROM=
# Reset-link TTL in minutes (default 30).
# LAX_PASSWORD_RESET_TTL_MIN=30

# Host/port are set on the command line in run.sh / run.bat.
